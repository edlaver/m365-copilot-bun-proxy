{
  "model": "m365-copilot",
  "stream": false,
  "instructions": "You are a coding assistant. Use tools for file inspection and edits.",
  "input": [
    {
      "type": "message",
      "role": "user",
      "content": [
        {
          "type": "input_text",
          "text": "Update src/app.ts so the header title says 'Project Atlas' instead of 'Project Apollo'. Read the file before editing it."
        }
      ]
    },
    {
      "type": "function_call",
      "id": "fc_read_file_1",
      "call_id": "call_read_file_1",
      "name": "read_file",
      "arguments": "{\"path\":\"src/app.ts\"}"
    },
    {
      "type": "function_call_output",
      "call_id": "call_read_file_1",
      "name": "read_file",
      "output": "export function App() {\n  return <h1>Project Apollo</h1>\n}\n"
    },
    {
      "type": "function_call",
      "id": "fc_apply_diff_1",
      "call_id": "call_apply_diff_1",
      "name": "apply_diff",
      "arguments": "{\"path\":\"src/app.ts\",\"search\":\"Project Apollo\",\"replace\":\"Project Atlas\"}"
    },
    {
      "type": "function_call_output",
      "call_id": "call_apply_diff_1",
      "name": "apply_diff",
      "output": "{\"ok\":true,\"path\":\"src/app.ts\",\"updated_content\":\"export function App() {\\n  return <h1>Project Atlas</h1>\\n}\\n\"}"
    }
  ],
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "read_file",
        "description": "Read a UTF-8 file from the workspace.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            }
          },
          "required": ["path"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "apply_diff",
        "description": "Apply a targeted diff edit to a file.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "search": {
              "type": "string"
            },
            "replace": {
              "type": "string"
            }
          },
          "required": ["path", "search", "replace"],
          "additionalProperties": false
        }
      }
    }
  ],
  "tool_choice": "auto"
}
