{
  "model": "{{model}}",
  "stream": false,
  "messages": [
    {
      "role": "system",
      "content": "You are a coding assistant. Use tools for file inspection and edits."
    },
    {
      "role": "user",
      "content": "Update src/app.ts so the header title says 'Project Atlas' instead of 'Project Apollo'. Read the file before editing it."
    },
    {
      "role": "assistant",
      "content": null,
      "tool_calls": [
        {
          "id": "call_read_file_1",
          "type": "function",
          "function": {
            "name": "read_file",
            "arguments": "{\"path\":\"src/app.ts\"}"
          }
        }
      ]
    },
    {
      "role": "tool",
      "tool_call_id": "call_read_file_1",
      "name": "read_file",
      "content": "export function App() {\n  return <h1>Project Apollo</h1>\n}\n"
    }
  ],
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "read_file",
        "description": "Read a UTF-8 file from the workspace.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            }
          },
          "required": ["path"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "apply_diff",
        "description": "Apply a targeted diff edit to a file.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "search": {
              "type": "string"
            },
            "replace": {
              "type": "string"
            }
          },
          "required": ["path", "search", "replace"],
          "additionalProperties": false
        }
      }
    }
  ],
  "tool_choice": "auto"
}
