{
  "model": "{{model}}",
  "stream": false,
  "messages": [
    {
      "role": "system",
      "content": "You are a concise weather assistant. Use tools when live weather data is needed."
    },
    {
      "role": "user",
      "content": "What is the weather in London right now, and should I bring an umbrella?"
    },
    {
      "role": "assistant",
      "content": null,
      "tool_calls": [
        {
          "id": "call_weather_london_1",
          "type": "function",
          "function": {
            "name": "get_weather",
            "arguments": "{\"location\":\"London, UK\",\"unit\":\"celsius\"}"
          }
        }
      ]
    },
    {
      "role": "tool",
      "tool_call_id": "call_weather_london_1",
      "name": "get_weather",
      "content": "{\"location\":\"London, UK\",\"temperature_c\":9,\"condition\":\"Light rain\",\"precipitation_chance\":82,\"wind_kph\":18}"
    }
  ],
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "get_weather",
        "description": "Get the latest weather for a city.",
        "parameters": {
          "type": "object",
          "properties": {
            "location": {
              "type": "string",
              "description": "City and region to look up."
            },
            "unit": {
              "type": "string",
              "enum": ["celsius", "fahrenheit"]
            }
          },
          "required": ["location"],
          "additionalProperties": false
        }
      }
    }
  ],
  "tool_choice": "auto"
}
